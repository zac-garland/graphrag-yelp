# Yelp & pipeline (Philadelphia has most restaurant data in this dataset; Austin not available)
TARGET_CITY=Philadelphia
YELP_DATA_PATH=Yelp JSON/yelp_dataset
# Or use data/raw if you symlink or copy Yelp JSON into project:
# YELP_DATA_PATH=data/raw

# Neo4j (Phase 2+)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# GraphRAG / LLM (Phase 3+)
ANTHROPIC_API_KEY=your_anthropic_key_here
